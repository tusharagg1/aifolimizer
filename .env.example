# Copy to backend/.env and fill in values. NEVER commit .env to git.

# Wealthsimple credentials - LOCAL ONLY, never deploy to cloud
WS_EMAIL=your@email.com
WS_PASSWORD=your_password

# Telegram bot notifications (optional - alerts sent here if set)
# 1. Create bot via @BotFather → copy token
# 2. Send any message to your bot → GET https://api.telegram.org/bot<TOKEN>/getUpdates → grab chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local infrastructure (Docker - defaults work with docker-compose.yml)
POSTGRES_DSN=postgresql://aifolimizer:aifolimizer@localhost:5432/aifolimizer
REDIS_URL=redis://localhost:6379/0

# LLM provider keys - OPTIONAL. Default (all blank): primary inference runs
# inside Claude Code / Claude Desktop Pro and NOTHING leaves your machine.
#
# Setting any of the keys below opts in to free-tier external LLM fallbacks.
# When enabled, prompts sent to that provider carry symbols, weights (% of
# NLV), returns %, scores, and public market data - NEVER absolute dollar
# balances, account IDs, email, name, or your WS token. Provider terms of
# service may log/retain the prompts they receive; check each one before
# enabling. Leave keys blank to keep all inference on-machine.
GITHUB_TOKEN=           # GitHub Models (GPT-4o-mini, free with GitHub Pro)
GOOGLE_API_KEY=         # Google AI Studio (Gemini Flash, free)
OPENROUTER_API_KEY=     # OpenRouter (Llama 3.3 70B free tier)
DASHSCOPE_API_KEY=      # Qwen / DashScope (Qwen-Plus)

# Error tracking - opt-in, leave blank to disable
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Free macro/sentiment sources below need NO key (Bank of Canada Valet,
# Statistics Canada, alternative.me Crypto Fear & Greed, Google Trends).
# FINNHUB_KEY (below) also unlocks company-news + insider-sentiment tools.

# Optional data-source providers (any blank = skip provider)
ALPHA_VANTAGE_KEY=       # Alpha Vantage equities/FX + FREE earnings-call transcripts for get_earnings_commentary (free tier, 25 req/day)
EODHD_KEY=               # EOD Historical Data (fundamentals + EOD prices)
FINNHUB_KEY=             # Finnhub quotes, news, earnings (free tier)
MASSIVE_API_KEY=         # Massive proxy/scraping API (optional fallback)
STOOQ_KEY=               # Stooq OHLCV data (CSV endpoint, key optional)
TIINGO_KEY=              # Tiingo EOD + IEX intraday (free tier)
TWELVE_DATA_KEY=         # Twelve Data quotes + technicals (free tier)

# Sentry PII guard
SENTRY_PII_TOKENS=       # optional, comma-separated extra PII substrings (e.g. your email prefix). Drop event if any token found.

# Runtime / debug
WS_DEBUG=                # optional, "1" enables verbose ws-api logging
WS_TOKEN_TTL_HOURS=      # optional, default 336 (14d). Range 1..720. Lower = more MFA, higher = longer stolen-laptop window.
STRUCTURED_LOGS=         # optional, "1" emits JSON logs
SESSION_COOKIE_SECURE=   # optional, "1" forces Secure flag on session cookies (HTTPS only)
