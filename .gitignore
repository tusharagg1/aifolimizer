# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# Wealthsimple session tokens (live credentials — never commit)
backend/.ws_session.json
*.ws_session.json

# Logs
*.log
backend_run.log
frontend_run.log

# Env (credentials)
.env
backend/.env
frontend/.env.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.orig

# Next.js (covered by frontend/.gitignore — listed here for root-level awareness)
frontend/.next/
frontend/out/
frontend/node_modules/

# Local runtime caches + logs (per-machine, not portable)
.claude/context/.diskcache/
.claude/context/alerts.jsonl
.claude/context/alerts_state.json
.claude/context/crowding_history.jsonl
.claude/context/recommendations.jsonl
.claude/context/scored_recommendations.jsonl
.claude/context/portfolio_history.jsonl
.claude/context/track_record_full.jsonl
backend/.pytest_cache/
backend/.cache/
backend/.claude/

# Backup files created by skill scaffolding / plugin tools
*.original.md

# Agent worktrees (per-session ephemeral checkouts)
.claude/worktrees/

# Runtime watchlist (user-specific, mutated by API)
backend/watchlist.json
